{
  "name": "@t3tools/annotations",
  "version": "0.1.0",
  "private": true,
  "description": "Extensao Chrome local para selecionar um elemento, anotar e copiar um screenshot para agentes de codigo.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "smoke": "bun run lint && bun run typecheck && bun run test && bun run build && bun run e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.326",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  }
}
